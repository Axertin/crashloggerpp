{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "mingw-x86-base",
            "hidden": true,
            "inherits": "base",
            "toolchainFile": "${sourceDir}/cmake/mingw-w64-i686.cmake"
        },
        {
            "name": "mingw-x86-debug",
            "displayName": "MinGW i686 (x86) Debug",
            "inherits": "mingw-x86-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "mingw-x86-release",
            "displayName": "MinGW i686 (x86) Release",
            "inherits": "mingw-x86-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "mingw-x64-base",
            "hidden": true,
            "inherits": "base",
            "toolchainFile": "${sourceDir}/cmake/mingw-w64-x86_64.cmake"
        },
        {
            "name": "mingw-x64-debug",
            "displayName": "MinGW x86_64 (x64) Debug",
            "inherits": "mingw-x64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "mingw-x64-release",
            "displayName": "MinGW x86_64 (x64) Release",
            "inherits": "mingw-x64-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "native-x86-debug",
            "displayName": "Native x86 Debug (MSVC/Clang)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "native-x86-release",
            "displayName": "Native x86 Release (MSVC/Clang)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "native-x64-debug",
            "displayName": "Native x64 Debug (MSVC/Clang)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "native-x64-release",
            "displayName": "Native x64 Release (MSVC/Clang)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "mingw-x86-debug",
            "configurePreset": "mingw-x86-debug"
        },
        {
            "name": "mingw-x86-release",
            "configurePreset": "mingw-x86-release"
        },
        {
            "name": "mingw-x64-debug",
            "configurePreset": "mingw-x64-debug"
        },
        {
            "name": "mingw-x64-release",
            "configurePreset": "mingw-x64-release"
        },
        {
            "name": "native-x86-debug",
            "configurePreset": "native-x86-debug"
        },
        {
            "name": "native-x86-release",
            "configurePreset": "native-x86-release"
        },
        {
            "name": "native-x64-debug",
            "configurePreset": "native-x64-debug"
        },
        {
            "name": "native-x64-release",
            "configurePreset": "native-x64-release"
        }
    ]
}
